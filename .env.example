# Example environment variables for PersonalKnowledgePool
# Copy this file to .env and replace placeholders before running the server

# SQLAlchemy / AsyncPG style connection string
DATABASE_URL=postgresql+asyncpg://<DB_USER>:<DB_PASSWORD>@localhost:5432/<DB_NAME>

# Example API key (NVIDIA). Replace with any provider key you use.
NVIDIA_API_KEY=nvapi-YOUR_KEY_HERE

# Optional: other API keys
# OPENAI_API_KEY=sk-...
# SEARXNG_URL=http://localhost:8888
